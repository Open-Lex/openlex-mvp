# OpenLex Environment Variables
# Kopiere diese Datei als .env und trage die echten Werte ein

# ChromaDB Pfad (optional, default: ./chromadb)
CHROMADB_DIR=

# HuggingFace Token (für Modell-Downloads)
HF_TOKEN=

# OpenRouter API Key
OPENROUTER_KEY=

# Mistral API Key
MISTRAL_KEY=

# Gradio Root Path (optional, z.B. für Reverse-Proxy)
GRADIO_ROOT_PATH=
