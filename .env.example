# OpenLex Environment Variables
# Kopiere diese Datei als .env und trage die echten Werte ein

# ChromaDB Pfad (optional, default: ./chromadb)
CHROMADB_DIR=

# HuggingFace Token (für Modell-Downloads)
HF_TOKEN=

# OpenRouter API Key
OPENROUTER_KEY=

# Mistral API Key
MISTRAL_KEY=

# Gradio Root Path (optional, z.B. für Reverse-Proxy)
GRADIO_ROOT_PATH=

# Cross-Encoder Reranker (Standard: MiniLM, Upgrade: bge-reranker-v2-m3)
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
OPENLEX_BM25_ENABLED=false
OPENLEX_TRACE_MODE=false
OPENLEX_BM25_INDEX_PATH=/opt/openlex-mvp/bm25_index

OPENLEX_REWRITE_ENABLED=false
OPENLEX_REWRITE_CACHE_PATH=/opt/openlex-mvp/cache/rewrite_cache.sqlite
OPENLEX_REWRITE_MODEL=mistral-medium-latest
OPENLEX_REWRITE_TIMEOUT_S=10

OPENLEX_FAITHFULNESS_MODEL=cross-encoder/nli-deberta-v3-large
OPENLEX_CE_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

OPENLEX_NORM_HYPOTHESIS_ENABLED=false
OPENLEX_NORM_HYPOTHESIS_CACHE_PATH=/opt/openlex-mvp/cache/norm_hypothesis_cache.sqlite
OPENLEX_NORM_HYPOTHESIS_MODEL=mistral-medium-latest

# Norm-Hypothesizer Schritt 1.2 (Shadow-Mode)
OPENLEX_NORM_HYPOTHESIS_ENABLED=false
OPENLEX_NORM_HYPOTHESIS_TIMEOUT_MS=8000
OPENLEX_NORM_HYPOTHESIS_LOG_PATH=/opt/openlex-mvp/logs/norm_hypothesis.jsonl

# Norm-Hypothesizer Schritt 1.3 (Pflicht-Chunk-Injection)
OPENLEX_NORM_HYPOTHESIS_INJECT_ENABLED=false  # default off
OPENLEX_NORM_HYPOTHESIS_MIN_CONFIDENCE=0.5    # Schwellwert für Injection
